// =====================================================================
// HiFiTaxa - PacBio HiFi 16S: DADA2 denoise -> BLCA (GTDB) taxonomy
// =====================================================================
manifest {
    name = 'HiFiTaxa'
    description = 'PacBio HiFi 16S: QIIME2/DADA2 denoising then BLCA, Emu or QIIME2 Naive-Bayes taxonomy against GTDB'
    mainScript = 'main.nf'
    nextflowVersion = '>=24.04,<25'
    version = '1.0.0'
}

params {
    help = false
    version = false

    // --- marker selection (drives primers, DADA2 length window, reference DBs,
    //     read-prep, NB design, and the read-level EM classifier) ---
    //   '16S' (default) : PacBio HiFi 16S, GTDB references, cutadapt -> DADA2,
    //                     two-step NB, Emu read-level profiler. UNCHANGED behaviour.
    //   'ITS'           : fungal ITS, UNITE references, cutadapt -> itsxrust ITS
    //                     extraction -> DADA2, single-step NB, EMITS read-level profiler.
    marker = '16S'

    // --- I/O ---
    input    = null          // samples TSV: <sample-id>\t<absolute-filepath>
    metadata = null          // metadata TSV: first column 'sample_name'
    asv_fasta = null         // for -entry taxonomy_only: start from an existing ASV fasta
    outdir   = "results"
    publish_dir_mode = "symlink"

    // --- QC / primer trimming ---
    skip_primer_trim = false
    filterQ   = 20
    downsample = 0
    // Primers + DADA2 length window switch on params.marker. The actual marker
    // defaults are assigned in the trailing `params {}` block at the BOTTOM of this
    // file (after `profiles {}`) so that selecting `-profile test_its` (which sets
    // marker='ITS') flips them correctly — a ternary placed here would be frozen at
    // the 16S base default before the profile merges. null here = "use marker
    // default"; pass --forward_primer/--reverse_primer/--min_len/--max_len to override.
    forward_primer = null   // marker default: 16S 27F / ITS 1391F            (see trailing params block)
    reverse_primer = null   // marker default: 16S 1492R / ITS revcomp(ITS4ngsUni)

    // --- DADA2 ---
    min_len = null          // marker default: 16S 1000 / ITS 200             (see trailing params block)
    max_len = null          // marker default: 16S 1600 / ITS 1300
    omegac  = "1e-40"
    max_ee  = 2
    minQ    = 0
    pooling_method = 'pseudo'
    // ASV-level filters applied after DADA2. They drop ASVs that look like
    // sequencing noise or singletons before BLCA / NB classification runs.
    //   min_asv_totalfreq : minimum SUMMED read count an ASV must have ACROSS
    //                       all samples to be kept (default 5). Lower → keep
    //                       rarer ASVs (more sensitive, more false positives).
    //   min_asv_sample    : minimum NUMBER OF SAMPLES an ASV must appear in
    //                       to be kept (default 1 → at least one sample).
    // Both auto-drop to 0 when only one sample is processed.
    min_asv_totalfreq = 5
    min_asv_sample    = 1
    learn_error_sample = null

    cutadapt_cpu = 2
    dada2_cpu    = 4

    // --- bundled scripts (dada scripts are staged as path inputs; the BLCA
    //     scripts live in bin/ and are auto-added to the task PATH by Nextflow) ---
    dadaCCS_script    = "${projectDir}/scripts/run_dada_2023.2.R"
    learnError_script = "${projectDir}/scripts/learnError.R"

    // --- BLCA reference database ---
    //   16S -> GTDB (db/gtdb_ssu_BLCAparsed.*); ITS -> UNITE (db_unite/unite_BLCAparsed.*).
    // blca_db/blca_tax resolve to the UNITE versions when marker=='ITS'; the actual
    // assignment is in the trailing `params {}` block (after profiles) for the same
    // profile-merge reason as the primers above. null = "use marker default".
    gtdb_db_dir  = "${projectDir}/db"
    unite_db_dir = "${projectDir}/db_unite"                                  // UNITE (ITS) reference dir
    blca_db  = null          // marker default: 16S gtdb_ssu_BLCAparsed.fasta / ITS unite_BLCAparsed.fasta
    blca_tax = null          // marker default: 16S gtdb_ssu_BLCAparsed.taxonomy / ITS unite_BLCAparsed.taxonomy
    blca_chunk_size = null   // ASVs per BLCA chunk; null = AUTO (~one chunk per usable core)
    max_cpus = Math.max(1, Runtime.runtime.availableProcessors() - 2)  // usable cores (available cores - 2, leaving 2 free); used to auto-chunk the BLCA step; override with --max_cpus
    blca_minid = 90          // BLCA min % identity
    blca_nper  = 100         // BLCA bootstrap iterations

    // --- GTDB release (pinned for reproducibility; 'latest' is opt-in in the launcher) ---
    gtdb_release = 'latest'   // 'latest' = query GTDB at runtime; pass an explicit release number to pin

    // --- conda envs (override on macOS to reuse an existing QIIME2 env) ---
    enable_conda = false
    qiime2_env = "${projectDir}/envs/qiime2-amplicon.yml"
    blca_env   = "${projectDir}/envs/blca.yml"

    // --- container image for the BLCA steps (QC/denoise reuse the modules' own
    //     pinned public images). Built & pushed to GHCR by .github/workflows. ---
    blca_container = 'ghcr.io/alegarritano/hifitax:1.0.0'

    // --- Classifier choice ---
    //   'blca' (default) : DADA2 ASVs -> BLCA against GTDB (per-rank bootstrap confidence)
    //   'emu'            : raw reads -> Emu EM-based species profiling
    //                      (Curry et al. 2022, Nat. Methods)
    //   'qiime2_nb'      : DADA2 ASVs -> QIIME2 Naive-Bayes classifier vs GTDB
    //                      (Wang et al. 2007, AEM; Bokulich et al. 2018, Microbiome).
    //                      Aliases: 'nb', 'dada2_nb', 'qiime2-nb', 'dada2-nb'.
    //   Combine with a comma-separated list (e.g. 'blca,emu', 'blca,emu,qiime2_nb') or
    //   use shorthand 'all' (== blca,emu,qiime2_nb) / 'both' (== blca,emu, legacy).
    classifier = null        // marker default: 16S -> blca (ASV path); ITS -> emits (read-level, paired with itsxrust). See trailing params block.

    // --- Emu ---
    emu_db_dir       = "${projectDir}/db_emu"                              // built by bin/build_gtdb_emu_db.sh
    emu_threads      = 4
    emu_type         = 'map-hifi'                                           // minimap2 preset; Emu 3.6+ ships map-hifi for PacBio HiFi; other options: map-ont, map-pb, sr, lr:hq
    emu_min_abundance = null                                                // null = Emu default (~10 reads); set 1e-5 etc. to relax
    emu_env          = "${projectDir}/envs/emu.yml"
    // Pinned to sha256 digest because biocontainers periodically rebuilds with new
    // suffixes and deletes the old (e.g. emu:3.6.2--pyhdfd78af_0 → 3.6.2--hdfd78af_0
    // in Mar 2026, breaking 'manifest unknown' on Singularity pull). Digest survives.
    emu_container    = 'quay.io/biocontainers/emu@sha256:61ea3336f12d41930d73e57ce1b041bce48d66b4011a165bf1f0efce9d684777'  // = emu:3.6.2--hdfd78af_0 (Mar 2026)

    // --- ITS read prep: itsxrust ITS extraction (marker==ITS only) ---
    // Runs between cutadapt and DADA2, pulling the full ITS1-5.8S-ITS2 span out of
    // the trimmed reads (see modules/itsx.nf). itsxrust is MIT licensed and on bioconda
    // (envs/itsxrust.yml) and ships an official container.
    itsx_threads   = params.max_cpus   // auto: all cores - 2 (see max_cpus); override with --itsx_threads
    itsx_hmm       = "${projectDir}/assets/itsxrust/F.hmm"   // anchor HMM profile required by `itsxrust extract --hmm` (bundled fungal F.hmm)
    itsx_container = 'ghcr.io/ayobi/itsxrust:latest'   // MIT; official image (also bioconda + quay.io/biocontainers). Pin a tag/digest for reproducibility.

    // --- EMITS (ITS read-level EM profiler; the fungal analogue of Emu) ---
    // marker==ITS replaces the Emu branch with EMITS: minimap2 (map-hifi) of the
    // itsxrust ITS-extracted, length-filtered reads against the staged UNITE FASTA, then
    // `emits run` resolves per-taxon abundance at species + genus rank (see modules/taxonomy_emits.nf).
    emits_db        = "${params.unite_db_dir}/unite.fasta"   // minimap2 target (bin/build_emits_db.sh)
    emits_threads   = params.max_cpus   // auto: all cores - 2 (see max_cpus); override with --emits_threads
    emits_container = 'ghcr.io/ayobi/emits:latest'   // MIT; official image (also bioconda + quay.io/biocontainers). Pin a tag/digest for reproducibility.

    // --- Naive-Bayes (DADA2 two-step: genus assignTaxonomy + exact-match species) ---
    // Canonical DADA2 design. assignTaxonomy() with the full SPECIES lineage in
    // headers does NOT scale to full GTDB SSU r232 (~82k species labels dilute the
    // bootstrap to Kingdom-only), so NB uses a GENUS-level reference for the
    // bootstrap step and a separate SPECIES reference for exact-match addSpecies():
    //   genus  : >Bacteria;Pseudomonadota;...;Escherichia              (6 ranks)
    //   species: >RS_GCF_000123.1 Escherichia coli                     (for addSpecies)
    // Both built by bin/build_gtdb_dada2_db.sh from the same BLCA-parsed GTDB that
    // BLCA + Emu use, so all three classifiers anchor on identical sequences.
    nb_db_dir             = "${projectDir}/db_nb"
    gtdb_dada2_genus_db   = "${params.nb_db_dir}/gtdb_ssu_dada2_genus.fa.gz"
    gtdb_dada2_species_db = "${params.nb_db_dir}/gtdb_ssu_dada2_species.fa.gz"
    nb_min_bootstrap      = 80   // DADA2 default
    dadaAssign_script     = "${projectDir}/scripts/dada2_assign_tax.R"

    // --- Naive-Bayes for ITS (single-step: 7-rank assignTaxonomy, NO addSpecies) ---
    // The two-step addSpecies design collapses to ~0 species on ITS/UNITE, so ITS
    // runs ONE assignTaxonomy() straight to Species against a 7-rank UNITE reference
    // with the full lineage already in the headers (built by bin/build_unite_dada2_db.sh).
    // See modules/taxonomy_nb.nf:nb_classify_singlestep + scripts/dada2_assign_tax_singlestep.R.
    unite_dada2_singlestep_db = "${params.unite_db_dir}/unite_full_singlestep_ref.fa.gz"
    dadaAssignSinglestep_script = "${projectDir}/scripts/dada2_assign_tax_singlestep.R"
}

// Process-name selectors are inlined in each withName below. They are prefix-aware
// ( (.*:)? matches names inside named workflows like taxonomy_only:blca_classify )
// and disjoint (the qiime2 set and the blca set never overlap).

// Reports (the launcher parses the trace file for the progress bar)
trace    { enabled = true; overwrite = true; file = "${params.outdir}/pipeline_trace.txt" }
timeline { enabled = true; overwrite = true; file = "${params.outdir}/execution_timeline.html" }
report   { enabled = true; overwrite = true; file = "${params.outdir}/execution_report.html" }

process {
    beforeScript = 'mkdir -p ./tmp/'
    withLabel: cpu_def { cpus = 4; memory = 16.GB }
}

profiles {
    // --- conda profiles: reuse existing/named conda envs (qiime2 + blca).
    //     Disjoint, prefix-aware withName selectors override each module's own
    //     conda() directive (a plain process.conda does NOT). ---
    standard {
        conda.enabled = true
        process {
            withName: '(.*:)?(write_log|QC_fastq.*|cutadapt.*|prepare_qiime2_manifest.*|merge_manifest|import_qiime2|demux_summarize|learn_error|dada2.*|mergeASV|filter_dada2|nb_classify|nb_classify_singlestep)' { conda = params.qiime2_env }
            withName: '(.*:)?(blca_classify|merge_blca)' { conda = params.blca_env }
            withName: '(.*:)?(emu_classify|emu_collate)' { conda = params.emu_env }
            // ITS marker: itsxrust extraction + EMITS read-level profiler (build-from-source envs)
            withName: '(.*:)?itsx_extract'   { conda = "${projectDir}/envs/itsxrust.yml" }
            withName: '(.*:)?emits_classify' { conda = "${projectDir}/envs/emits.yml" }
        }
    }
    conda {
        conda.enabled = true
        conda.cacheDir = "${System.getenv('HOME')}/.HiFiTaxa_conda"
        process {
            withName: '(.*:)?(write_log|QC_fastq.*|cutadapt.*|prepare_qiime2_manifest.*|merge_manifest|import_qiime2|demux_summarize|learn_error|dada2.*|mergeASV|filter_dada2|nb_classify|nb_classify_singlestep)' { conda = params.qiime2_env }
            withName: '(.*:)?(blca_classify|merge_blca)' { conda = params.blca_env }
            withName: '(.*:)?(emu_classify|emu_collate)' { conda = params.emu_env }
            // ITS marker: itsxrust extraction + EMITS read-level profiler (build-from-source envs)
            withName: '(.*:)?itsx_extract'   { conda = "${projectDir}/envs/itsxrust.yml" }
            withName: '(.*:)?emits_classify' { conda = "${projectDir}/envs/emits.yml" }
        }
    }
    // --- container profiles (cross-OS reproducible). QC/denoise use the modules'
    //     own pinned public images (kpinpb/pb-16s-nf-tools, quay.io/qiime2/amplicon);
    //     only the BLCA steps need an image, set via params.blca_container. ---
    docker {
        docker.enabled = true
        conda.enabled  = true   // itsx_extract + emits_classify run via their self-contained conda envs (procps/nhmmer baked in); see withName below
        // platform pin: qiime2/pbtools images are linux/amd64 (needed on Apple Silicon);
        // bind-mount the GTDB DB dirs so containers can read them.
        // Bind-mount only the DB dirs that ACTUALLY EXIST. Docker / Singularity
        // refuse to start when asked to mount a nonexistent source — that's the
        // crash you get on a fresh install where only --classifier blca is used
        // and db_emu/ + db_nb/ are absent. Conditional binds make this safe.
        docker.runOptions = (
            "--platform linux/amd64 -u \$(id -u):\$(id -g)" +
            " -v ${params.gtdb_db_dir}:${params.gtdb_db_dir}" +
            (new File(params.emu_db_dir.toString()).isDirectory()   ? " -v ${params.emu_db_dir}:${params.emu_db_dir}"     : "") +
            (new File(params.nb_db_dir.toString()).isDirectory()    ? " -v ${params.nb_db_dir}:${params.nb_db_dir}"       : "") +
            (new File(params.unite_db_dir.toString()).isDirectory() ? " -v ${params.unite_db_dir}:${params.unite_db_dir}" : "")
        )
        process {
            withName: '(.*:)?(blca_classify|merge_blca)' { container = params.blca_container }
            withName: '(.*:)?(emu_classify|emu_collate)' { container = params.emu_container }
            // itsxrust + EMITS ship as stripped static-binary images that lack `ps`
            // (breaks Nextflow task metrics) and nhmmer, so run them via their
            // self-contained conda envs (itsxrust+hmmer+minimap2 / emits+minimap2).
            // Use a pre-built conda_envs/<tool> if present (build it on an HPC login
            // node alongside the images; the offline compute node then needs no build),
            // else fall back to the yml so Nextflow auto-builds it where there's internet.
            withName: '(.*:)?itsx_extract'   { container = null; conda = (new File("${projectDir}/conda_envs/itsxrust").isDirectory() ? "${projectDir}/conda_envs/itsxrust" : "${projectDir}/envs/itsxrust.yml") }
            withName: '(.*:)?emits_classify' { container = null; conda = (new File("${projectDir}/conda_envs/emits").isDirectory() ? "${projectDir}/conda_envs/emits" : "${projectDir}/envs/emits.yml") }
            // NB runs DADA2 R + QIIME2 export inside the QIIME2 image.
            // QIIME2's image $HOME (/home/qiime2) is read-only and q2cli/numba/matplotlib
            // write there (q2cli resolves it from the passwd db, ignoring $HOME), so mount
            // the writable, per-task work dir over it.
            withName: '(.*:)?(import_qiime2|demux_summarize|learn_error|dada2.*|mergeASV|filter_dada2|nb_classify|nb_classify_singlestep)' {
                containerOptions = { "-v ${task.workDir}:/home/qiime2" }
            }
        }
    }
    singularity {
        singularity.enabled = true
        conda.enabled       = true   // itsx_extract + emits_classify run via their self-contained conda envs (procps/nhmmer baked in); see withName below
        singularity.autoMounts = true
        singularity.cacheDir = System.getenv('NXF_SINGULARITY_CACHEDIR') ?: "${launchDir}/singularity_cache"
        // See note above for docker.runOptions — bind only existing DB dirs so
        // a fresh --classifier blca run doesn't fail trying to mount db_emu/db_nb.
        singularity.runOptions = (
            "--bind ${params.gtdb_db_dir}" +
            (new File(params.emu_db_dir.toString()).isDirectory()   ? " --bind ${params.emu_db_dir}"   : "") +
            (new File(params.nb_db_dir.toString()).isDirectory()    ? " --bind ${params.nb_db_dir}"    : "") +
            (new File(params.unite_db_dir.toString()).isDirectory() ? " --bind ${params.unite_db_dir}" : "")
        )
        process {
            withName: '(.*:)?(blca_classify|merge_blca)' { container = params.blca_container }
            withName: '(.*:)?(emu_classify|emu_collate)' { container = params.emu_container }
            // itsxrust + EMITS ship as stripped static-binary images that lack `ps`
            // (breaks Nextflow task metrics) and nhmmer, so run them via their
            // self-contained conda envs (itsxrust+hmmer+minimap2 / emits+minimap2).
            // Use a pre-built conda_envs/<tool> if present (build it on an HPC login
            // node alongside the images; the offline compute node then needs no build),
            // else fall back to the yml so Nextflow auto-builds it where there's internet.
            withName: '(.*:)?itsx_extract'   { container = null; conda = (new File("${projectDir}/conda_envs/itsxrust").isDirectory() ? "${projectDir}/conda_envs/itsxrust" : "${projectDir}/envs/itsxrust.yml") }
            withName: '(.*:)?emits_classify' { container = null; conda = (new File("${projectDir}/conda_envs/emits").isDirectory() ? "${projectDir}/conda_envs/emits" : "${projectDir}/envs/emits.yml") }
            // NB runs DADA2 R + QIIME2 export inside the QIIME2 image.
            withName: '(.*:)?(import_qiime2|demux_summarize|learn_error|dada2.*|mergeASV|filter_dada2|nb_classify|nb_classify_singlestep)' {
                containerOptions = { "--bind ${task.workDir}:/home/qiime2" }
            }
        }
    }
    // --- bundled example run (8-sample ATCC mock, 16S). Pair with -profile docker/standard. ---
    test {
        params.input    = "${projectDir}/example/samples.tsv"
        params.metadata = "${projectDir}/example/metadata.tsv"
        params.blca_chunk_size = 10
    }
    // --- bundled example run (small fungal ITS mock). Mirrors `test` but marker='ITS'
    //     (UNITE references, itsxrust extraction, single-step NB, EMITS).
    //     Pair with -profile docker/standard. ---
    test_its {
        params.marker   = 'ITS'
        params.input    = "${projectDir}/example_its/samples.tsv"
        params.metadata = "${projectDir}/example_its/metadata.tsv"
        params.blca_chunk_size = 10
    }
}

// =====================================================================
// Marker-dependent defaults (resolved AFTER profiles merge).
// This trailing params{} block is evaluated once profile selection (e.g.
// -profile test_its, which sets params.marker='ITS') has been applied, so the
// 16S/ITS switch sees the final marker. Each line only fills a value the user
// left null, so explicit --forward_primer / --min_len / --blca_db ... overrides
// still win. (NB: a CLI-only `--marker ITS` without -profile test_its does NOT
// re-trigger these — config is parsed before run-time --params; select ITS via
// -profile test_its, or also pass the marker-specific params explicitly.)
// =====================================================================
params {
    // Primers (cutadapt linked adapter FWD...REV in modules/qc.nf:cutadapt).
    classifier = params.classifier ?: (params.marker == 'ITS' ? 'emits' : 'blca')   // ITS -> read-level EMITS (no DADA2 unless blca/nb asked); 16S -> BLCA
    forward_primer = params.forward_primer ?: (params.marker == 'ITS' ? 'GTACACACCGCCCGTC'    : 'AGRGTTYGATYMTGGCTCAG')  // ITS 1391F : 16S 27F
    reverse_primer = params.reverse_primer ?: (params.marker == 'ITS' ? 'GCATATHANTAAGSGSAGG' : 'AAGTCGTAACAAGGTARCY')    // ITS revcomp(ITS4ngsUni) : 16S 1492R

    // DADA2 length window. 16S = full SSU (1000-1600). ITS is short and is
    // itsxrust-extracted (ITS1-5.8S-ITS2) before DADA2, so 200-1300.
    min_len = params.min_len != null ? params.min_len : (params.marker == 'ITS' ? 200  : 1000)
    max_len = params.max_len != null ? params.max_len : (params.marker == 'ITS' ? 1300 : 1600)

    // BLCA reference: GTDB for 16S, UNITE for ITS.
    blca_db  = params.blca_db  ?: (params.marker == 'ITS' ? "${params.unite_db_dir}/unite_BLCAparsed.fasta"
                                                          : "${params.gtdb_db_dir}/gtdb_ssu_BLCAparsed.fasta")
    blca_tax = params.blca_tax ?: (params.marker == 'ITS' ? "${params.unite_db_dir}/unite_BLCAparsed.taxonomy"
                                                          : "${params.gtdb_db_dir}/gtdb_ssu_BLCAparsed.taxonomy")
}
